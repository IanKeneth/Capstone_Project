<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit User info</title>
    <style>
        .modal {
            display: flex;
            justify-content: center;
            align-items: center;
            position: fixed;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
        }
        .modal-content {
            background-color: #fff;
            padding: 2rem;
            border-radius: 12px;
            width: 90%;
            max-width: 450px;
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.2);
            border-top: 5px solid #e67e22; 
            animation: modalPop 0.3s ease-out;
        }
        .modal-content h2 {
            margin-bottom: 1.5rem;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            font-size: 1.5rem;
            text-align: center;
        }

        .modal-content label {
            display: block;
            font-size: 0.9rem;
            font-weight: 600;
            color: #555;
            margin-bottom: 5px;
        }
        .modal-content input {
            width: 100%;
            padding: 12px;
            margin-bottom: 1.2rem;
            border: 1px solid #ddd;
            border-radius: 6px;
            font-size: 1rem;
            box-sizing: border-box;
            transition: border-color 0.3s;
        }

        .modal-content input:focus {
            border-color: #e67e22;
            outline: none;
            box-shadow: 0 0 5px rgba(230, 126, 34, 0.2);
        }
        .modal-content input[readonly] {
            background-color: #f4f4f4;
            color: #777;
            cursor: not-allowed;
            border-style: dashed;
        }
        .modal-content button {
            width: 100%;
            padding: 12px;
            border: none;
            border-radius: 6px;
            font-size: 1rem;
            font-weight: bold;
            cursor: pointer;
            margin-bottom: 10px;
            transition: all 0.2s;
        }

        .modal-content button[type="submit"] {
            background-color: #e67e22;
            color: white;
        }

        .modal-content button[type="submit"]:hover {
            background-color: #e67e22;
            transform: translateY(-1px);
        }
        .modal-content button[type="button"]:hover {
            background-color: #e67e22;
            transform: translateY(-1px);
        }


        .modal-content button[type="button"] {
            background-color: #e67e22;
            color:white;
        }
        @keyframes modalPop {
            from { opacity: 0; transform: scale(0.9); }
            to { opacity: 1; transform: scale(1); }
        }
        </style>
</head>
<body>
     <div  class="modal">
            <div class="modal-content">
                <h2 style="color: #e67e22;">Update Users</h2>

                <form action="/update" method="GET">
                            <label>Id:</label>
                            <input type="text" name="id" value="<%= mydata.id %>" readonly>

                            <label>Name:</label>
                            <input type="text" name="name" value="<%= mydata.name %>" readonly>

                            <label>Email:</label>
                            <input type="email" name="email" value="<%= mydata.email %>" readonly>

                            <label>Role:</label>
                            <input type="text" name="role" value="<%= mydata.role %>" required>

                            <button type="submit">Update</button>
                            <button type="button" onclick="window.location.href='/User-management'">Cancel</button>
                        </form>
                    </div>
                </div>
            </section>
        </main>
    </div>

</body>
</html>