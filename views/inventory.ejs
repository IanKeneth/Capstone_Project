<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Inventory - Admin Dashboard</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="style.css">
    <style>
        .inventory-container {
            display: block;
            padding: 20px;
            min-height: 100vh;
        }

        .inventory-card {
            background: white;
            border: 1px solid #e0e0e0;
            border-radius: 8px;
            padding: 20px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.05);
        }

        .inventory-card h2 {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 15px;
            color: #333;
            margin-bottom: 25px;
            border-bottom: 1px solid #eee;
            padding-bottom: 15px;
        }

        .inventory-table {
            width: 100%;
            border-collapse: collapse;
        }

        .inventory-table th {
            background-color: #fdfdfd;
            color: #666;
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 1px;
            padding: 15px;
            border-bottom: 2px solid #f28c28;
            text-align: center;
        }

        .inventory-table td {
            padding: 15px;
            border-bottom: 1px solid #eee;
            text-align: center;
        }

        .modal {
            display: none; 
            position: fixed;
            z-index: 9999;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0,0,0,0.5);
            /* These center the modal-content */
            justify-content: center; 
            align-items: center;
        }

        .modal-content {
            background: #fff;
            padding: 30px;
            width: 400px;
            border-radius: 10px;
            position: relative;
            box-shadow: 0 4px 20px rgba(0,0,0,0.2);
        }

        .modal-content h2 {
            margin-top: 0;
            font-size: 1.5rem;
            text-align: center;
        }

        .modal-content label {
            display: block;
            margin-top: 10px;
            font-weight: bold;
            color: #555;
        }

        .modal-content input {
            width: 100%;
            padding: 10px;
            margin: 5px 0 15px;
            border: 1px solid #ccc;
            border-radius: 5px;
            box-sizing: border-box;
        }

        .close {
            position: absolute;
            right: 20px;
            top: 15px;
            cursor: pointer;
            font-size: 24px;
            color: #999;
        }

        .btn-add {
            width: 100%;
            padding: 10px;
            background-color: white;
            color: #e67e22;
            border: 1px solid #e67e22;
            border-radius: 5px;
            cursor: pointer;
            font-weight: bold;
            transition: 0.3s;
        }

        .btn-add:hover {
            background-color: #e67e22;
            color: white;
        }

        .refresh-btn {
            background-color: #f28c28;
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 5px;
            cursor: pointer;
            font-weight: bold;
        }

        .d-flex { display: flex; align-items: center; }
        .gap-2 { gap: 8px; }
        .btn { text-decoration: none; padding: 5px 10px; border-radius: 4px; font-size: 0.8rem; }
        .btn-danger { border: 1px solid #e67e22; color: #e67e22; }
    </style>
</head>
<body>

    <div class="container">
        <aside class="sidebar">
            <div class="sidebar-header">
                <i class="fa-solid fa-boxes-stacked"></i> 
                <span>Title</span>
            </div>

            <nav>
                <a href="/index" class="nav-item">
                    <i class="fa-solid fa-chart-line icon"></i> 
                    <span>Dashboard</span>
                </a>
                <a href="/inventory" class="nav-item active">
                    <i class="fa-solid fa-boxes-packing icon"></i> 
                    <span>Inventory</span>
                </a>
                 <a href="/supplies" class="nav-item ">
                    <i class="fa-solid fa-truck-ramp-box icon"></i> 
                    <span>Supplies</span>
                </a>
                <a href="/track&reports" class="nav-item">
                    <i class="fa-solid fa-file-invoice-dollar icon"></i> 
                    <span>Track & Reports</span>
                </a>
                <a href="/User-management" class="nav-item">
                    <i class="fa-solid fa-users icon"></i> 
                    <span>User Management</span>
                </a>
                <a href="/settings" class="nav-item">
                    <i class="fa-solid fa-gears icon"></i> 
                    <span>Settings</span>
                </a>
            </nav>

            <div class="sidebar-footer">
                <a href="/login" class="nav-item">
                    <i class="fa-solid fa-right-from-bracket icon"></i> 
                    <span>Logout</span>
                </a>
            </div>

        </aside>

        <main class="main-content">
            <header class="header">
                <div class="header-left">
                    <button id="sidebarToggle" class="hamburger-btn">
                        <i class="fa-solid fa-bars"></i>
                    </button>
                    <h1>Inventory Management</h1>
                </div>
                <div class="user-profile">
                    <i class="fa-solid fa-circle-user"></i>
                </div>
            </header>

            <section class="inventory-container">
                <div class="inventory-card">
                    <h2><i class="fa-solid fa-share-nodes"></i> View Current Stock Levels</h2>
                    
                    <table class="inventory-table">
                        <thead>
                            <tr>
                                <th>Product Id</th>
                                <th>Product Name</th>
                                <th>Category</th>
                                <th>Price</th>
                                <th>Qty</th>
                                <th>Max Quantity %</th>
                                <th>Stock percent</th>
                                <th>Stock Alert</th>
                                <th>Action  </th>

                            </tr>
                        </thead>
                        <tbody>
                        <% if(products.length > 0) { %>
                            <% products.forEach((myData) => { %>
                                <tr>
                                    <td><%- myData.id %></td>
                                    <td><%- myData.product_name %></td>
                                    <td><%- myData.category %></td>
                                    <td><%- myData.price %></td>
                                    <td ><%- myData.quantity %></td>
                                    <td ><%- myData.max_quantity %></td>
                                    <td id="stock_percent"><%- myData.stock_percent %></td>
                                    <td id="alert-cell">    </td>
                                    <td>
                                        <div class="d-flex gap-2">
                                            <a href="/delete/<%-myData.id%>" class="btn btn-danger">Delete</a>
                                            <a href="/edit/<%-myData.id%>" class="btn btn-danger">Update</a>
                                        </div>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="7">No products found</td>
                            </tr>
                        <% } %>
                        </tbody>
                    </table>
                    <button id="btn" class="refresh-btn" style="margin-top: 30px;" onclick="openForm()">Add Products</button>

                    <div id="popupForm"  class="modal">
                        <div style="margin: 10px;" class="modal-content">
                            <span class="close" onclick="closeForm()">&times;</span>
                            <h2 style="color: #e67e22;">Supplies list</h2>

                            <form action="/add" method="POST">
                                <label>Product Name</label>
                                <input type="text" name="product_name"  required>
                                
                                <label>Category</label>
                                <input type="text" name="category"  required>

                                <label>Price</label>
                                <input type="number" name="price" required>

                                <label>Quantity:</label>
                                <input type="number" id="quantity" name="quantity"  required>

                                <label>Max_Quantity:</label>
                                <input type="number" id="max-quantity" name="max_quantity" required>

                                <button type="submit" style="color: #e67e22;">Add</button>
                            </form>
                        </div>
                        </div>
                    </div>
            </section>
        </main>
    </div>

    <script>
        const sidebar = document.querySelector('.sidebar');
        const toggleBtn = document.getElementById('sidebarToggle');

        toggleBtn.addEventListener('click', () => {
            sidebar.classList.toggle('collapsed');
        });

        function openForm() {
        document.getElementById("popupForm").style.display = "flex";
        }

        function closeForm() {
        document.getElementById("popupForm").style.display = "none";
        }
    </script>
</body>
</html>